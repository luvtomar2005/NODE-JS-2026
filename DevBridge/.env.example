PORT=3000
DB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<db-name>
JWT_SECRET=replace_with_secure_secret
SES_VERIFIED_EMAIL=you@example.com
CORS_ORIGINS=http://localhost:5173,https://your-frontend-domain.com

# SECURITY NOTES:
# 1) Never commit real credentials to Git (.env must stay local/secret manager only).
# 2) If any secret is leaked, rotate immediately:
#    - MongoDB Atlas: create a new DB user/password and revoke old credentials.
#    - JWT secret: generate a new strong secret and redeploy.
# 3) Deleting hardcoded secrets from code is NOT enough once pushed:
#    secrets still exist in git history. Clean history with:
#    - git filter-repo (recommended), or
#    - BFG Repo-Cleaner
#    then force-push and revoke old credentials.
